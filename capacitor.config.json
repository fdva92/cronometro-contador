{
  "appId": "com.cronometro.contador",
  "appName": "Cronometro Contador",
  "webDir": "dist",
  "bundledWebRuntime": false,
  "server": {
    "url": "https://fdva92.github.io/cronometro-contador/",
    "cleartext": true
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 3000,
      "launchAutoHide": true,
      "backgroundColor": "#667eea",
      "androidSplashResourceName": "splash",
      "androidScaleType": "CENTER_CROP"
    }
  }
}